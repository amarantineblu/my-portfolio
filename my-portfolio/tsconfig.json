{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "types": ["jest", "node"],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,
    "allowSyntheticDefaultImports": true   // 👈 prevents .js files from being generated
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "vite.config.ts",
    "jest.config.ts"
  ]
}
